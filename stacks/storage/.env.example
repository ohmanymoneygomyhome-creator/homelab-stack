# Storage Stack Environment Variables

# Domain
DOMAIN=homelab.local
STORAGE_PATH=/data/storage

# =============================================================================
# Nextcloud
# =============================================================================
NEXTCLOUD_DOMAIN=cloud.${DOMAIN}
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change_me_secure
NEXTCLOUD_DB_PASSWORD=nextcloud_secret

# =============================================================================
# MinIO
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password

# =============================================================================
# FileBrowser
# =============================================================================
# FileBrowser will be accessible at files.${DOMAIN}
# Default credentials after first login: admin / admin

# Timezone
TZ=Asia/Shanghai
