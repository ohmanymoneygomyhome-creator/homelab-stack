# Network Stack Environment Variables
# Copy to .env and configure

# Domain
DOMAIN=homelab.local

# =============================================================================
# AdGuard Home
# =============================================================================
# AdGuard listens on port 53 by default, which may conflict with systemd-resolved
# Run ./scripts/fix-dns-port.sh to resolve

# =============================================================================
# WireGuard Easy VPN
# =============================================================================
WG_HOST=vpn.example.com
WG_EASY_PASSWORD=change_me_secure_password

# =============================================================================
# Cloudflare DDNS
# =============================================================================
CF_API_KEY=your_cloudflare_api_key
CF_API_EMAIL=your@email.com
CF_ZONE_ID=your_zone_id
CF_RECORD_NAME=ddns.example.com
CF_RECORD_TYPE=A

# =============================================================================
# Unbound (Recursive DNS)
# =============================================================================
# Unbound configuration is in config/unbound/

# Timezone
TZ=Asia/Shanghai
